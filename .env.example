# LgNc local configuration.
# Copy this file to .env and adjust as needed. Everything is optional --
# you can also add API keys later from the in-app Settings screen.

# Port for the local backend server.
SERVER_PORT=8787

# Where to store your local SQLite database and secret key.
# Defaults to a `.lgnc` folder in your home directory if unset.
# LGNC_DATA_DIR=./data

# Optional: seed API keys via environment instead of the Settings UI.
# Keys added in the app are encrypted at rest; these env values are read as-is.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# Optional: base URL for a local Ollama server (no key required).
OLLAMA_BASE_URL=http://localhost:11434

# Request Limiting Configuration
# Body size limits (in bytes)
MAX_BODY_SIZE=51200              # 50 KB for general endpoints
MAX_CHAT_BODY_SIZE=204800        # 200 KB for /api/chat (allows longer messages)

# Rate limiting (per IP, per window)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=60000       # Time window in milliseconds (1 minute = 60000)
RATE_LIMIT_MAX_REQUESTS=100      # Max requests per IP per window
